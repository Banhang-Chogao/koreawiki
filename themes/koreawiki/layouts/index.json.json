[
{{- range $i, $page := where .Site.RegularPages "Type" "not in" (slice "page") -}}
  {{- if $i -}},{{- end -}}
  {
    "title": {{ $page.Title | jsonify }},
    "description": {{ $page.Description | jsonify }},
    "permalink": {{ $page.Permalink | jsonify }},
    "tags": {{ $page.Params.tags | jsonify }},
    "categories": {{ $page.Params.categories | jsonify }},
    "section": {{ $page.Section | humanize | jsonify }},
    "date": {{ $page.Date.Format "January 2, 2006" | jsonify }},
    "content": {{ $page.Plain | truncate 500 | jsonify }}
  }
{{- end -}}
]
